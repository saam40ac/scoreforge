# ─────────────────────────────────────────────
#  SCOREFORGE — Variabili d'ambiente
#  Copia questo file in .env.local e compila i valori
# ─────────────────────────────────────────────

# SUPABASE
# Trovi questi valori in: Supabase Dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL pubblica dell'app (in sviluppo usa localhost, in produzione il tuo dominio)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── FASE 2 (quando apri al pubblico) ─────────
# CLOUDFLARE R2 (storage audio e immagini)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=scoreforge-media
# R2_PUBLIC_URL=https://media.scoreforge.io

# STRIPE (pagamenti abbonamenti)
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# RESEND (email transazionali)
# RESEND_API_KEY=re_...
